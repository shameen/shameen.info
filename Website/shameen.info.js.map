
define('text!views/experiments.html',[],function () { return '<section>\n  <h2 data-bind="text:title"></h2>\n  <blockquote data-bind="text:subHeader"></blockquote>\n  <div class="row" data-bind="foreach: experimentList">\n    <div class="col-xs-12">\n      <div class="bs-callout bs-callout-default">\n        <h3 data-bind="text: title"></h3>\n        <p data-bind="text: description"></p>\n        <a\n          data-bind="attr: {href: url}, text: url, style: {\'text-decoration\': functional ? \'\' : \'line-through\'}"\n        ></a>\n\n        <div>\n          <span data-bind="foreach: tags">\n            <span class="label label-primary" data-bind="text: $data"></span>\n          </span>\n\n          <span class="label label-success" data-bind="visible: functional"\n            >Working</span\n          >\n          <span class="label label-danger" data-bind="visible: !functional"\n            >Not fully functional</span\n          >\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n';});

