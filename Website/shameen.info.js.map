
define('text!views/work.html',[],function () { return '<section>\n  <h2 data-bind="text: title"></h2>\n  <div data-bind="foreach: portfolioItems">\n    <div class="row well">\n      <div style="max-width: 640px; display: inline-block">\n        <img\n          data-bind="attr: { src: img }"\n          style="max-width: 640px; max-height: 480px; width: 100%; margin: auto"\n        />\n      </div>\n      <div style="display: inline-block; width: 300px; margin: 0 4%">\n        <h3 data-bind="text: title"></h3>\n        <p data-bind="html: description"></p>\n        <div class="external-link" data-bind="with: link">\n          <a\n            data-bind="attr: {href: url}, css: {_strikethrough: !active}, text: url, enable: active, visible: url != null"\n            target="_blank"\n            title="Opens in New Tab"\n          ></a>\n        </div>\n        <p data-bind="foreach: tags">\n          <span class="label label-default" data-bind="text: $data"></span>\n        </p>\n      </div>\n    </div>\n  </div>\n</section>\n';});

