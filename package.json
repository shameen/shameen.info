{
  "name": "shameen.info",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Personal website and portfolio of Shameen — software engineer, experiments, and projects.",
  "author": "Shameen <https://github.com/shameen>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shameen/shameen.info.git"
  },
  "homepage": "https://shameen.github.io/shameen.info",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo '' && simple-git-hooks || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-themes": "^10.4.2",
    "@storybook/sveltekit": "^10.4.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.4.2",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.4.2",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16"
  },
  "simple-git-hooks": {
    "pre-commit": "npm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,svelte,json,css,md}": [
      "prettier --write"
    ],
    "*.{js,ts,svelte}": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": "^22.11.0 || ^24.11.0"
  }
}
